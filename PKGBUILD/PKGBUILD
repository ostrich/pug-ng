pkgname=pug-ng
pkgver=0.1
pkgrel=1
pkgdesc='Sync repo and AUR package lists to GitHub Gists via an ALPM hook'
arch=('any')
url='https://github.com/ostrich/pug-ng'
license=('custom')
depends=('bash' 'curl' 'jq' 'pacman')
makedepends=('git' 'make')
backup=('etc/pug-ng/config')
install='pug-ng.install'
source=("${pkgname}::git+${url}.git#tag=v${pkgver}")
sha256sums=('SKIP')

package() {
  cd "${srcdir}/${pkgname}"
  make DESTDIR="${pkgdir}" install
}
